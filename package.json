{
  "name": "systems-thinking-mcp",
  "version": "0.1.0",
  "description": "MCP server providing systems thinking models as composable analysis lenses",
  "type": "module",
  "bin": {
    "systems-thinking-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "models",
    "strategies"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "chalk": "^5.3.0",
    "js-yaml": "^4.1.0",
    "yargs": "^17.7.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.32",
    "shx": "^0.3.4",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  }
}
